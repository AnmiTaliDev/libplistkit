#ifndef PLISTKIT_VERSION_H
#define PLISTKIT_VERSION_H

#define PLISTKIT_VERSION_MAJOR @VERSION_MAJOR@
#define PLISTKIT_VERSION_MINOR @VERSION_MINOR@
#define PLISTKIT_VERSION_PATCH @VERSION_PATCH@
#define PLISTKIT_VERSION_STRING "@VERSION@"

/**
 * Check at compile time if the library version is at least the given version.
 */
#define PLISTKIT_VERSION_CHECK(major, minor, patch) \
    ((PLISTKIT_VERSION_MAJOR > (major)) || \
     (PLISTKIT_VERSION_MAJOR == (major) && PLISTKIT_VERSION_MINOR > (minor)) || \
     (PLISTKIT_VERSION_MAJOR == (major) && PLISTKIT_VERSION_MINOR == (minor) && \
      PLISTKIT_VERSION_PATCH >= (patch)))

#endif /* PLISTKIT_VERSION_H */
